/*
 * Falcon Keymap
 *
 * 34 keys total: 17 per half
 *   - 3 rows × 5 cols  = 15 main keys per half
 *   - 1 thumb row, inner 2 cols = 2 thumb keys per half
 *
 * Physical layout (L = left half, R = right half):
 *
 *  ┌─────┬─────┬─────┬─────┬─────┐   ┌─────┬─────┬─────┬─────┬─────┐
 *  │ L00 │ L01 │ L02 │ L03 │ L04 │   │ R00 │ R01 │ R02 │ R03 │ R04 │
 *  ├─────┼─────┼─────┼─────┼─────┤   ├─────┼─────┼─────┼─────┼─────┤
 *  │ L10 │ L11 │ L12 │ L13 │ L14 │   │ R10 │ R11 │ R12 │ R13 │ R14 │
 *  ├─────┼─────┼─────┼─────┼─────┤   ├─────┼─────┼─────┼─────┼─────┤
 *  │ L20 │ L21 │ L22 │ L23 │ L24 │   │ R20 │ R21 │ R22 │ R23 │ R24 │
 *  └─────┴─────┴─────┴─────┼─────┤   ├─────┼─────┴─────┴─────┴─────┘
 *                           │ L33 │   │ R33 │
 *                           ├─────┤   ├─────┤
 *                           │ L34 │   │ R34 │
 *                           └─────┘   └─────┘
 *
 * ZMK key ordering (left half keys first, then right half):
 *   L00 L01 L02 L03 L04  R00 R01 R02 R03 R04
 *   L10 L11 L12 L13 L14  R10 R11 R12 R13 R14
 *   L20 L21 L22 L23 L24  R20 R21 R22 R23 R24
 *                   L33 L34  R33 R34
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/pointing.h>

#define BASE 0
#define NAV  1
#define SYM  2
#define BT   3

/ {
    keymap {
        compatible = "zmk,keymap";

        /* ── Layer 0: QWERTY ─────────────────────────────────────────── */
        base_layer {
            bindings = <
        /*  col0        col1        col2        col3        col4            col0        col1        col2        col3        col4   */
            &kp Q       &kp W       &kp E       &kp R       &kp T           &kp Y       &kp U       &kp I       &kp O       &kp P
            &kp A       &kp S       &kp D       &kp F       &kp G           &kp H       &kp J       &kp K       &kp L       &kp SEMI
            &kp Z       &kp X       &kp C       &kp V       &kp B           &kp N       &kp M       &kp COMMA   &kp DOT     &kp FSLH
        /*                                      thumb inner                thumb inner                                           */
                                                &mo NAV     &kp LSHFT       &kp SPACE   &mo SYM
            >;
        };

        /* ── Layer 1: Navigation / Numbers ──────────────────────────── */
        nav_layer {
            bindings = <
            &kp N1      &kp N2      &kp N3      &kp N4      &kp N5          &kp N6      &kp N7      &kp N8      &kp N9      &kp N0
            &kp TAB     &kp LALT    &kp LCTRL   &kp LGUI    &none           &kp LEFT    &kp DOWN    &kp UP      &kp RIGHT   &kp BSPC
            &kp LCTRL   &none       &none       &none       &mo BT          &kp HOME    &kp PG_DN   &kp PG_UP   &kp END     &kp DEL
                                                &trans      &trans           &kp RET    &trans
            >;
        };

        /* ── Layer 2: Symbols ────────────────────────────────────────── */
        sym_layer {
            bindings = <
            &kp EXCL    &kp AT      &kp HASH    &kp DLLR    &kp PRCNT       &kp CARET   &kp AMPS    &kp ASTRK   &kp LPAR    &kp RPAR
            &kp GRAVE   &kp TILDE   &kp MINUS   &kp EQUAL   &kp PIPE        &kp LBKT    &kp RBKT    &kp LBRC    &kp RBRC    &kp APOS
            &kp CAPS    &none       &kp UNDER   &kp PLUS    &kp BSLH        &none       &none       &kp LT      &kp GT      &kp QMARK
                                                &trans      &trans           &trans      &trans
            >;
        };

        /* ── Layer 3: Bluetooth ──────────────────────────────────────── */
        bt_layer {
            bindings = <
            &bt BT_SEL 0 &bt BT_SEL 1 &bt BT_SEL 2 &bt BT_SEL 3 &bt BT_SEL 4   &none  &none  &none  &none  &bt BT_CLR
            &none        &none        &none        &none        &none             &none  &none  &none  &none  &none
            &none        &none        &none        &none        &trans            &none  &none  &none  &none  &sys_reset
                                                   &trans       &trans            &trans &trans
            >;
        };
    };
};
