if SHIELD_FALCON_DONGLE

config ZMK_KEYBOARD_NAME
    default "Falcon"

config ZMK_SPLIT_ROLE_CENTRAL
    default y

config ZMK_SPLIT
    default y

# 2 peripherals: left half + right half
config ZMK_SPLIT_BLE_CENTRAL_PERIPHERALS
    default 2

# BT_MAX_CONN = peripherals + desired BT profiles (default 5)
config BT_MAX_CONN
    default 7

config BT_MAX_PAIRED
    default 7

config ZMK_POINTING
    default y

endif
